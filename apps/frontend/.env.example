# =============================================================================
# GST Reconciliation Frontend — Environment Variables
# Copy this file to .env.local and fill in your values before starting the app.
# =============================================================================

# --- Backend API URL ---------------------------------------------------------
# Full URL of the running backend server.
# Must match the PORT set in apps/backend/.env (default: 3001).
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
