# =============================================================================
# GST Reconciliation Backend — Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# =============================================================================

# --- Database (Required) -----------------------------------------------------
# MongoDB Atlas connection string for storing reconciliation data
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gst_reconciliation

# --- AI / LLM Keys (Required) ------------------------------------------------
# OpenAI API key — used for invoice matching (GPT-4o, hardcoded) and ITC embeddings
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google API key — used for Gemini AI explanations (Phase 7)
GOOGLE_API_KEY=AIza-your-google-api-key-here

# --- Server ------------------------------------------------------------------
# HTTP port the backend server listens on (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins (default: http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000

# Maximum file upload size in megabytes (default: 10)
MAX_UPLOAD_SIZE_MB=10

# --- Cloud Storage — AWS S3 / Cloudflare R2 (Optional, Phase 3) --------------
# Leave blank to use local storage instead of S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# For Cloudflare R2, set to: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Leave blank for standard AWS S3
S3_ENDPOINT_URL=

# --- Authentication (Phase 2) ------------------------------------------------
# Secret key used for signing JWT tokens — use a long random string in production
SECRET_KEY=change-me-in-production

# --- AI Model Configuration --------------------------------------------------
# OpenAI embedding model used by the ITC Rules Engine (Phase 6); change if you want a different model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini chat model for AI explanations (Phase 7)
GEMINI_MODEL=gemini-1.5-pro

# --- PDF Generation (Phase 8) ------------------------------------------------
# PDF rendering backend: "weasy" (default, no extra install) or "chromium"
PDF_BACKEND=weasy
